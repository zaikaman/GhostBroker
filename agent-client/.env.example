[TEMPLATE]
# GhostBroker connection
GHOSTBROKER_URL=http://localhost:3001

# Agent authentication
# Persistent API key from the dashboard API Keys panel.
# The SDK exchanges this for a short-lived session token.
GHOSTBROKER_API_KEY=gbk_replace_me

# Agent identity
AGENT_DID=did:t3n:0xYourAgentAddress

# Institution
INSTITUTION_ID=00000000-0000-4000-8000-000000000000

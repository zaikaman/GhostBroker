# ============================================================================
# GhostBroker frontend (Vercel) — environment template
# Copy to frontend/.env (gitignored) for local dev, and set the same keys
# in the Vercel project settings (Settings → Environment Variables) for
# production builds. Vite bakes VITE_* vars into the bundle at build time,
# so changing these values requires a redeploy.
# ============================================================================

# Backend API base URL (the Heroku web dyno).
# - Local dev:  http://localhost:3001
# - Heroku:     https://<your-heroku-app>.herokuapp.com
# - DO NOT include a trailing slash (the api-client normalizes anyway).
VITE_API_BASE_URL=http://localhost:3001

# WebSocket telemetry stream URL (same host as the API, /ws/telemetry path).
# - Local dev:  ws://localhost:3001/ws/telemetry
# - Heroku:     wss://<your-heroku-app>.herokuapp.com/ws/telemetry
# (Heroku terminates TLS at the router, so always use wss:// in production.)
VITE_WS_TELEMETRY_URL=ws://localhost:3001/ws/telemetry

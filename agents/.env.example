# ─── GhostBroker connection ──────────────────────────────────────────────
GHOSTBROKER_URL=http://localhost:3001
GHOSTBROKER_API_KEY=gbk_re...n

# ─── Terminal 3 onboarding (Ghostbroker delegation flow) ──────────────────────────
# The ONLY T3 secret the agent needs. Get it from
# https://www.terminal3.io/claim-page
T3N_API_KEY=...n
# Testnet T3N node. The Ghostbroker delegation BUIDL uses the Singapore
# testnet endpoint; the public testnet is also at
# https://cn-api.sg.testnet.t3n.terminal3.io
T3N_API_URL=https://cn-api.sg.testnet.t3n.terminal3.io

# Where `setup:identity` writes the agent identity file (DID + keypair)
# and where `setup:delegation` writes the W3C VC. Defaults shown.
AGENT_IDENTITY_CONFIG_PATH=output/identities/agent_identity.json
DELEGATION_CREDENTIAL_PATH=output/delegations/agent_delegation.json

# Verifier mode on the server. Default: `live` — cryptographic
# verification of the `EcdsaSecp256k1Signature2019` proof the
# `setup:delegation` script writes. The verifier falls back to
# `structural` if `@terminal3/verify_vc` throws, unless
# `VC_VERIFY_STRICT=true`. Use `sandbox` only for offline
# integration tests where the SDK isn't reachable.
VC_VERIFY_MODE=live

# ─── LLM provider chain (Gemini primary, OpenAI fallback, Groq last) ───────
# The agent tries each provider in turn and falls back on transient
# failures (5xx, 429, network, empty/malformed responses). Auth and
# 400 errors are fatal — the same prompt won't work on a different
# provider either. At least ONE of these keys must be set.
#
# Override the chain with LLM_PROVIDER_CHAIN="openai,gemini,groq" etc.
# Provider ids: gemini, openai, groq.

# Primary — Gemini via the v98store proxy. Get a key from the
# workspace's Gemini project (or the v98store proxy if you are not
# the workspace owner). Endpoint defaults to
# https://v98store.com/v1beta — override only if the proxy changes.
GEMINI_API_KEY=sk_replace_me
GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_BASE_URL=https://v98store.com/v1beta

# Fallback #1 — OpenAI-compatible chat completions (Azure OpenAI in
# this workspace). Default base URL is the Azure-hosted gpt-5-nano;
# override only if you are pointing at a different tenant.
OPENAI_API_KEY=sk_replace_me
OPENAI_MODEL=gpt-5-nano
# OPENAI_BASE_URL=https://roguegoescrazy.openai.azure.com/openai/v1

# Fallback #2 — Groq Cloud. https://console.groq.com/keys
GROQ_API_KEY=gsk_replace_me
GROQ_MODEL=qwen/qwen3-32b

# Optional explicit chain override (default: gemini,openai,groq).
# LLM_PROVIDER_CHAIN=gemini,openai,groq

# ─── Trading parameters (the bounds the LLM operates inside) ────────────
# Both agents share the same reference price and band so a match is
# possible. The buyer bid lands in the upper half, seller ask in the
# lower half. Tune the band tighter for faster matching.
REFERENCE_PRICE_USDC_PER_WBTC=70000
PRICE_BAND_BPS=200                       # ±2% around the reference
QUANTITY_MIN_WBTC=0.0001
QUANTITY_MAX_WBTC=0.0001

# ─── Loop tuning ─────────────────────────────────────────────────────────
TICK_INTERVAL_MS=15000                  # 15s between LLM calls
MAX_TICKS=40                            # 40 × 15s = 10 min cap

# Set DRY_RUN=1 to log LLM decisions without submitting. Useful for
# sanity-checking the prompt before going live.
DRY_RUN=0

# Optional fallback balances for the LLM prompt. The agent's
# PRIMARY balance source is `client.getAgentPortfolio(...)` in the
# run loop, which reads the live `portfolios.balance - locked` for
# each holding from the backend. These env vars are only used when
# the SDK call fails (e.g. transient 503 from the backend).
#
# Leave both unset for the safe default: on a portfolio read
# failure, the LLM is told "0 available" and the agent waits for
# the SDK to recover. Set them only if you have a specific reason
# to let the agent continue trading with a stale balance hint.
# The orchestrator's balance-lock check is the real authority on
# whether a submit will succeed.
# AGENT_AVAILABLE_USDC=10000
# AGENT_AVAILABLE_WBTC=10

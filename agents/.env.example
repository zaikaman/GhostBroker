[TEMPLATE]
# --- GhostBroker connection ---
# Required. Points to the running backend.
GHOSTBROKER_URL=http://localhost:3001

# --- Hosted agent authentication ---
# When the backend spawns a hosted agent it injects these via process.env
# automatically. Listed here for manual debugging.
#
# GHOSTBROKER_SESSION_TOKEN=eyJh...
# GHOSTBROKER_SESSION_EXPIRES_AT=...
# GHOSTBROKER_INSTITUTION_ID=...
# HOSTED_AGENT_ID=...
# HOSTED_MANDATE_ID=...

# --- Agent identity ---
AGENT_IDENTITY_CONFIG_PATH=output/identities/agent_identity.json
# AGENT_IDENTITY_DID=did:t3n:agent:...

# --- LLM provider chain ---
GEMINI_API_KEY=sk_replace_me
GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_BASE_URL=https://v98store.com/v1beta
OPENAI_API_KEY=sk_replace_me
OPENAI_MODEL=gpt-5-nano
# OPENAI_BASE_URL=https://roguegoescrazy.services.ai.azure.com/openai/v1
GROQ_API_KEY=gsk_replace_me
GROQ_MODEL=qwen/qwen3-32b
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# LLM_PROVIDER_CHAIN=gemini,openai,groq

# --- Loop tuning ---
POLL_INTERVAL_MS=15000
MAX_TICKS=40
# AGENT_QUOTE_ASSET_CODE=USDC
# DRY_RUN=0

# --- Legacy buyer/seller only ---
# GHOSTBROKER_API_KEY=gbk_re...n
# REFERENCE_PRICE_USDC_PER_WBTC=70000
# PRICE_BAND_BPS=200
# QUANTITY_MIN_WBTC=0.0001
# QUANTITY_MAX_WBTC=0.0001
# TICK_INTERVAL_MS=15000

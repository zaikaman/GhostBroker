{
  "name": "@ghostbroker/negotiation-core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared negotiation strategy, turn-context, and decision-validation math consumed by the backend orchestrator and the hosted agent runtime. Single source of truth for derived execution rails and LLM-move bounds.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: see root'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}

T3N_API_KEY=<developer-key-from-terminal3-claim-page>
T3N_ENV=testnet
T3_NETWORK_URL=
T3_TENANT_DID=
T3_SANDBOX_TOKEN_ACCOUNT=<sandbox-token-account-or-did>
T3_MINIMUM_TOKEN_BALANCE=1

# ADK environment: which Terminal 3 network surface the enclave
# talks to. `sandbox` for local development (no billing), `testnet`
# for the public T3N testnet, `production` for the billable
# mainnet. Read by `t3-enclave/src/sandbox/config.ts`; surfaced
# in the `sandbox:check` JSON output.
T3_ADK_ENV=sandbox

# Whether the Terminal 3 agent-auth Host API is wired in. The
# reviewed public docs mark the surface as "coming soon"; the
# GhostVerifier falls back to the Ghostbroker-style structural
# path while this is anything other than `live`. The startup
# check (T3-ONB-001) emits a warning when `live` is selected
# because the underlying surface is not yet shipped.
T3_AUTH_SDK_ENV=sandbox

# Agent delegation mode. `dashboard` means agent grants are
# provisioned out-of-band via the (currently non-existent) T3
# dashboard; the startup check refuses to boot a production
# backend in this mode unless the operator has pre-verified at
# least one agent DID via `T3_VERIFIED_AGENT_DIDS` on the
# backend. `programmatic` is reserved for when the T3
# agent-auth Host API ships. See
# `docs/terminal3-adk-onboarding-doc-gaps.md` (T3-ONB-001).
T3_AGENT_DELEGATION_MODE=dashboard

# Whether the startup check fails closed when dashboard mode is
# selected and no agent grant has been verified. Set to `false`
# only as a documented operator override; the default `true` is
# the P0 remediation.
T3_AGENT_GRANT_VERIFICATION_REQUIRED=true

T3_PRIVATE_MAP_PREFIX=ghostbroker-dev

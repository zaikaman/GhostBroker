T3N_API_KEY=<developer-key-from-terminal3-claim-page>
T3N_ENV=testnet
T3_NETWORK_URL=
T3_TENANT_DID=
T3_SANDBOX_TOKEN_ACCOUNT=<sandbox-token-account-or-did>
T3_MINIMUM_TOKEN_BALANCE=1

# ADK environment: which Terminal 3 network surface the enclave
# talks to. `sandbox` is the bundled offline mode (no SDK calls);
# `testnet` is the public T3N testnet where the 20,000 free
# test tokens from https://www.terminal3.io/claim-page live —
# this is the GhostBroker default for dev + live trades on
# Sepolia testnet. `production` is the billable mainnet. The
# startup check warns if `production` is selected without
# explicit operator acknowledgement.
T3_ADK_ENV=testnet

# Verification mode for the GhostBroker-style W3C VC verifier
# (`t3-enclave/src/auth/ghostbroker-delegation.ts`).
#   - `live`       — require cryptographic verification via
#                    `@terminal3/verify_vc` (`verifyEcdsaVc`
#                    for `EcdsaSecp256k1Signature2019` proofs).
#                    GhostBroker default; matches the JWS the
#                    `setup:delegation` script produces. Falls
#                    back to `structural` if `@terminal3/verify_vc`
#                    throws, unless `VC_VERIFY_STRICT=true`.
#   - `structural` — shape + time-window + DID-binding checks
#                    with no crypto. The "no SDK available"
#                    fallback.
#   - `sandbox`    — structural checks only; sandbox proof
#                    markers pass. Use only for offline
#                    integration tests.
# Also reads `VC_VERIFY_MODE` as a fallback for compatibility.
T3_MODE=live

T3_PRIVATE_MAP_PREFIX=ghostbroker-dev

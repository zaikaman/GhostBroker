// WIT world for the GhostBroker matching TEE contract.
//
// T3N host calls this contract at six routes, all under the
// `matching` tail the GhostBroker orchestrator hits via the
// `T3BlindIntentClient`, `T3NegotiationTicketClient`, and
// `T3NegotiationRoundClient` in `backend/src/enclave/`. The
// functions are pure (no host I/O) and produce deterministic
// opaque handles the orchestrator threads through its
// in-memory queue.
//
// Tail: `matching` (must match the T3 contract-name + the
// `contractPath` defaults in the t3-enclave clients).
package ghostbroker:matching-policy@0.9.1;

world contract {
  import host:tenant/tenant-context@1.0.0;
  import host:interfaces/logging@2.1.0;
  import host:interfaces/kv-store@2.1.0;

  export contracts;
}

interface contracts {
  // Shared input envelope. Mirrors the procurement-policy
  // `generic-input` shape so the T3 host can dispatch without
  // a per-contract path.
  record generic-input {
    input: option<list<u8>>,
    user-profile: option<list<u8>>,
    context: option<list<u8>>,
  }

  // ─── seal-ticket ───
  //
  // Seal a negotiation ticket. The orchestrator dispatches here
  // from `/contracts/negotiation/tickets`. Creates an opaque
  // handle that is bound to EVERY input field — including
  // `policy_hash` and `compatibility_token` — so a different
  // token produces a different handle. The contract is
  // intentionally non-validating beyond structural field
  // presence: the orchestrator already verified the Ghostbroker
  // delegation VC before calling; the TEE's job is to mint a
  // tamper-evident handle, not re-check policy.
  //
  // Input  (JSON): SealTicketInput
  //   {
  //     "institution_id":      "<uuid>",
  //     "agent_did":           "did:t3n:...",
  //     "authority_ref":       "ghostbroker-delegation:...",
  //     "asset_code":          "WBTC",
  //     "side":                "buy" | "sell",
  //     "policy_hash":         "<hex>",
  //     "compatibility_token": "WBTC:buy:<institution-id>",
  //     "correlation_ref":     "ticket:...",
  //   }
  // Output (JSON): SealTicketOutput
  //   {
  //     "ticket_handle":  "ticket_<32-hex>",
  //     "execution_ref":  "t3exec_<uuid>",
  //   }
  seal-ticket: func(req: generic-input) -> result<list<u8>, string>;

  // Seal an encrypted blind intent. The host returns a fresh
  // opaque handle the orchestrator uses as the in-memory queue
  // key. The contract is intentionally non-validating: the
  // orchestrator already verified the Ghostbroker delegation
  // VC before calling; the TEE's job is to mint a tamper-evident
  // handle, not re-check policy.
  //
  // Input  (JSON): SealIntentInput
  //   {
  //     "institution_id":   "<uuid>",
  //     "agent_did":        "did:t3n:...",
  //     "encrypted_intent": "<base64url envelope>",
  //     "authority_ref":    "ghostbroker-delegation:...",
  //     "correlation_ref":  "corr_...",
  //   }
  // Output (JSON): SealIntentOutput
  //   {
  //     "intent_handle":  "intent_<32-hex>",
  //     "execution_ref":  "t3exec_<uuid>",
  //   }
  seal-intent: func(req: generic-input) -> result<list<u8>, string>;

  // Evaluate whether two sealed intents (one buy, one sell) can
  // match, and if so decide the fill quantity and execution price.
  // As of v0.2.0 the enclave is match-authoritative: the caller
  // sends both sides' asset code, prices, and quantities, and the
  // contract returns `status: "matched"` with `matched_quantity`
  // and `execution_price` only when the buyer's bid crosses the
  // seller's ask. The orchestrator is a verifier around the
  // enclave outcome, not the price matcher.
  //
  // v0.8.0: the caller must also pass the per-side identity
  // (`buy_institution_id`, `sell_institution_id`,
  // `buy_authority_ref`, `sell_authority_ref`). The TEE echoes
  // those fields back on both `matched` and `no_match` outcomes
  // and binds them to the `match_attestation_ref` so the audit
  // log carries a TEE-attested identity instead of an
  // orchestrator-stamped override. The orchestrator asserts the
  // echo matches the queue values it submitted and fails closed
  // on mismatch.
  //
  // Input  (JSON): EvaluateMatchInput
  //   {
  //     "buy_intent_handle":   "intent_...",
  //     "sell_intent_handle":  "intent_...",
  //     "correlation_ref":     "corr_...",
  //     "asset_code":          "WBTC",
  //     "buy_price":           "<decimal-string>",
  //     "buy_quantity":        "<decimal-string>",
  //     "sell_price":          "<decimal-string>",
  //     "sell_quantity":       "<decimal-string>",
  //     "buy_institution_id":  "<uuid>",
  //     "sell_institution_id": "<uuid>",
  //     "buy_authority_ref":   "ghostbroker-delegation:...",
  //     "sell_authority_ref":  "ghostbroker-delegation:...",
  //   }
  // Output (JSON): EvaluateMatchOutput
  //   {
  //     "outcome_ref":              "outcome_<32-hex>",
  //     "execution_ref":            "t3exec_<uuid>",
  //     "buyer_institution_id":     "<uuid>",     // echoed from input
  //     "seller_institution_id":    "<uuid>",     // echoed from input
  //     "encrypted_trade_fields_ref":"t3fields_<32-hex>",
  //     "buyer_authority_ref":      "...",        // echoed from input
  //     "seller_authority_ref":     "...",        // echoed from input
  //     "expires_at":               "<iso8601>",
  //     "status":                   "matched" | "no_match",
  //     "matched_quantity":         "<decimal-string>",  // "" on no_match
  //     "execution_price":          "<decimal-string>",  // "" on no_match
  //     "match_attestation_ref":    "match_attest_<32-hex>",
  //   }
  evaluate-match: func(req: generic-input) -> result<list<u8>, string>;

  // Structural pair authority for negotiation tickets. The
  // orchestrator owns the in-memory pending queue but must call
  // this function before creating a session for a candidate
  // pair; the TEE returns `status: "compatible"` only when
  // every structural axis agrees. This is the load-bearing pair
  // decision — without a `compatible` outcome the orchestrator
  // MUST NOT create a session, regardless of what its local
  // (asset, side, institution) filter found. The TEE is
  // stateless: it does not remember which tickets it has sealed
  // and trusts the orchestrator to pass real handles from a
  // real `seal-ticket` call. What it DOES verify is the shape
  // of the attestation — handles are well-formed, compatibility
  // tokens parse to a real (asset, side, institution) tuple,
  // and the two sides agree on the structural axes a malicious
  // or buggy orchestrator could otherwise violate.
  //
  // Input  (JSON): EvaluatePairInput
  //   {
  //     "buy_ticket_handle":       "ticket_<32-hex>",
  //     "sell_ticket_handle":      "ticket_<32-hex>",
  //     "buy_compatibility_token": "WBTC:buy:<institution-id>",
  //     "sell_compatibility_token":"WBTC:sell:<institution-id>",
  //     "asset_code":              "WBTC",
  //     "correlation_ref":         "pair:...",
  //   }
  // Output (JSON): EvaluatePairOutput
  //   {
  //     "pair_ref":              "pair_<32-hex>",
  //     "execution_ref":         "t3exec_<uuid>",
  //     "status":                "compatible" | "incompatible",
  //     "reason":                "<human-readable>",
  //     "reason_code":           "<stable-machine-readable>",   // "" on compatible
  //     "buy_ticket_handle":     "ticket_<32-hex>",            // echo
  //     "sell_ticket_handle":    "ticket_<32-hex>",            // echo
  //     "buy_institution_id":    "<uuid>",                     // "" on incompatible
  //     "sell_institution_id":   "<uuid>",                     // "" on incompatible
  //     "asset_code":            "WBTC",
  //     "expires_at":            "<iso8601>",
  //   }
  //
  // Reason codes (all on `status: "incompatible"`):
  //   * `missing_<field>`                 — required input field is empty
  //   * `malformed_<side>_ticket_handle`  — handle does not match
  //                                         ^ticket_[0-9a-f]{32}$
  //   * `malformed_<side>_compatibility_token`
  //                                       — token does not parse to
  //                                         <asset>:<side>:<institution>
  //   * `<side>_token_wrong_side`         — buy/sell side label mismatch
  //   * `<side>_token_asset_mismatch`     — explicit asset_code disagrees
  //                                         with the asset in the token
  //   * `asset_mismatch`                  — buy and sell tokens disagree
  //                                         on the asset
  //   * `same_institution`                — both tokens reference the same
  //                                         institution (a side is trying
  //                                         to pair with itself)
  //   * `self_pair`                       — both ticket handles are equal
  evaluate-pair: func(req: generic-input) -> result<list<u8>, string>;

  // — Per-round negotiation crosses (v0.9.0) —
  //
  // Each agent runtime seals its priced proposal into an AES-256-GCM
  // AEAD envelope with the institution's per-institution key derived
  // from `ENVELOPE_ENCRYPTION_MASTER_KEY` via HKDF-SHA256 (the same
  // cipher used by hidden intents — see `enclave/keys/envelope-cipher.ts`).
  // The orchestrator forwards both sides' sealed envelopes + AAD context
  // to `seal-round-proposal` and `evaluate-round` so the cross-evaluation
  // path never sees plaintext price / quantity on the backend side.
  // The TEE holds the only decryption key inside its boundary.

  // seal-round-proposal: unseal one envelope, mint a `round_<handle>`,
  // and return the TEE-attested per-side descriptor. The orchestrator
  // forwards the handle to `evaluate-round` so the TEE can pair the
  // cross with the exact envelope bytes it unsealed on the seal path.
  //
  // Input  (JSON): SealRoundProposalInput
  //   {
  //     "sealed_envelope":  "ghostbroker.envelope.aead/v1|...",
  //     "institution_did":  "<did:t3n:...>",
  //     "agent_did":        "did:t3n:...",
  //     "authority_ref":    "ghostbroker-delegation:...",
  //     "asset_code":       "WBTC",
  //     "side":             "buy" | "sell",
  //     "correlation_ref":  "round:...",
  //   }
  // Output (JSON): SealRoundProposalOutput
  //   {
  //     "proposal_handle":   "round_<32-hex>",
  //     "execution_ref":     "t3exec_<uuid>",
  //     "traded_asset_code": "WBTC",
  //     "side":              "buy" | "sell",
  //     "quantity":          "<decimal-string>",
  //     "price":             "<decimal-string>",
  //     "distance_signal":   "crossed" | "near" | "moderate" | "far",
  //     "attestation_ref":   "roundattest_seal_<32-hex>",
  //     "sealed_at":         "<iso8601>",
  //   }
  seal-round-proposal: func(req: generic-input) -> result<list<u8>, string>;

  // evaluate-round: given two opaque proposal handles from
  // `seal-round-proposal`, unseal both envelopes inside the enclave,
  // decide the cross (bid >= ask + both quantities > 0), compute
  // the midpoint execution price and `min(buy_quantity, sell_quantity)`
  // fill, and emit a TEE-attested `round_attestation_ref` that
  // cryptographically binds the verdict to the proposal handles the
  // TEE unsealed.
  //
  // Input  (JSON): EvaluateRoundInput
  //   {
  //     "buy_proposal_handle":  "round_<32-hex>",
  //     "sell_proposal_handle": "round_<32-hex>",
  //     "asset_code":           "WBTC",
  //     "correlation_ref":      "round-eval:...",
  //   }
  // Output (JSON): EvaluateRoundOutput
  //   {
  //     "status":                  "crossed" | "open",
  //     "buyer_signal":            "crossed" | "near" | "moderate" | "far",
  //     "seller_signal":           "crossed" | "near" | "moderate" | "far",
  //     "outcome_ref":             "round_outcome_<32-hex>",
  //     "execution_ref":           "t3exec_<uuid>",
  //     "encrypted_trade_fields_ref": "t3fields_round_<32-hex>",
  //     "expires_at":              "<iso8601>",
  //     "evaluated_at":            "<iso8601>",
  //     "matched_quantity":        "<decimal-string>",   // "" on open
  //     "execution_price":         "<decimal-string>",   // "" on open
  //     "round_attestation_ref":   "roundattest_<32-hex>",
  //   }
  //
  // Distance signal bucketing matches the public `distanceSignalFor`
  // helper in `backend/src/enclave/negotiation/round-client.ts` so
  // a fallback computation on a pre-v0.9.0 host returns the same
  // label the TEE would emit. The bucket thresholds (relative to
  // the ask): `crossed` when bid >= ask; `near` when the gap is
  // <= 1% of the ask; `moderate` when <= 5%; `far` otherwise.
  evaluate-round: func(req: generic-input) -> result<list<u8>, string>;
}

// WIT world for the GhostBroker matching TEE contract.
//
// T3N host calls this contract at two routes, both under the
// `matching` tail the GhostBroker orchestrator hits via the
// `T3BlindIntentClient` and `T3MatchContractClient` in
// `t3-enclave/src/matching/`. Both functions are pure
// (no host I/O) and produce deterministic opaque handles the
// orchestrator threads through its in-memory queue.
//
// Tail: `matching` (must match the T3 contract-name + the
// `contractPath` defaults in the t3-enclave clients).
package ghostbroker:matching-policy@0.2.0;

world contract {
  import host:tenant/tenant-context@1.0.0;
  import host:interfaces/logging@2.1.0;

  export contracts;
}

interface contracts {
  // Shared input envelope. Mirrors the procurement-policy
  // `generic-input` shape so the T3 host can dispatch without
  // a per-contract path.
  record generic-input {
    input: option<list<u8>>,
    user-profile: option<list<u8>>,
    context: option<list<u8>>,
  }

  // ─── seal-ticket ───
  //
  // Seal a negotiation ticket. The orchestrator dispatches here
  // from `/contracts/negotiation/tickets`. Creates an opaque handle
  // from the negotiation ticket fields so the orchestrator can pair
  // opposite-side tickets in memory. The contract is intentionally
  // non-validating: the orchestrator already verified the
  // GhostBroker delegation VC before calling; the TEE's job is to
  // mint a tamper-evident handle, not re-check policy.
  //
  // Input  (JSON): SealTicketInput
  //   {
  //     "institution_id":      "<uuid>",
  //     "agent_did":           "did:t3n:...",
  //     "authority_ref":       "ghostbroker-delegation:...",
  //     "asset_code":          "WBTC",
  //     "side":                "buy" | "sell",
  //     "policy_hash":         "<hex>",
  //     "compatibility_token": "WBTC:buy:<institution-id>",
  //     "correlation_ref":     "ticket:...",
  //   }
  // Output (JSON): SealTicketOutput
  //   {
  //     "ticket_handle":  "ticket_<32-hex>",
  //     "execution_ref":  "t3exec_<uuid>",
  //   }
  seal-ticket: func(req: generic-input) -> result<list<u8>, string>;

  // Seal an encrypted blind intent. The host returns a fresh
  // opaque handle the orchestrator uses as the in-memory queue
  // key. The contract is intentionally non-validating: the
  // orchestrator already verified the GhostBroker delegation
  // VC before calling; the TEE's job is to mint a tamper-evident
  // handle, not re-check policy.
  //
  // Input  (JSON): SealIntentInput
  //   {
  //     "institution_id":   "<uuid>",
  //     "agent_did":        "did:t3n:...",
  //     "encrypted_intent": "<base64url envelope>",
  //     "authority_ref":    "ghostbroker-delegation:...",
  //     "correlation_ref":  "corr_...",
  //   }
  // Output (JSON): SealIntentOutput
  //   {
  //     "intent_handle":  "intent_<32-hex>",
  //     "execution_ref":  "t3exec_<uuid>",
  //   }
  seal-intent: func(req: generic-input) -> result<list<u8>, string>;

  // Evaluate whether two sealed intents (one buy, one sell) can
  // match, and if so decide the fill quantity and execution price.
  // As of v0.2.0 the enclave is match-authoritative: the caller
  // sends both sides' asset code, prices, and quantities, and the
  // contract returns `status: "matched"` with `matched_quantity`
  // and `execution_price` only when the buyer's bid crosses the
  // seller's ask. The orchestrator is a verifier around the
  // enclave outcome, not the price matcher.
  //
  // Input  (JSON): EvaluateMatchInput
  //   {
  //     "buy_intent_handle":  "intent_...",
  //     "sell_intent_handle": "intent_...",
  //     "correlation_ref":    "corr_...",
  //     "asset_code":         "WBTC",
  //     "buy_price":          "<decimal-string>",
  //     "buy_quantity":       "<decimal-string>",
  //     "sell_price":         "<decimal-string>",
  //     "sell_quantity":      "<decimal-string>",
  //   }
  // Output (JSON): EvaluateMatchOutput
  //   {
  //     "outcome_ref":               "outcome_<32-hex>",
  //     "execution_ref":             "t3exec_<uuid>",
  //     "buyer_institution_id":      "",   // stamped by orchestrator
  //     "seller_institution_id":     "",   // stamped by orchestrator
  //     "encrypted_trade_fields_ref": "t3fields_<32-hex>",
  //     "buyer_authority_ref":       "",   // stamped by orchestrator
  //     "seller_authority_ref":      "",   // stamped by orchestrator
  //     "expires_at":                "<iso8601>",
  //     "status":                    "matched" | "no_match",
  //     "matched_quantity":          "<decimal-string>",  // "" on no_match
  //     "execution_price":           "<decimal-string>",  // "" on no_match
  //   }
  evaluate-match: func(req: generic-input) -> result<list<u8>, string>;
}

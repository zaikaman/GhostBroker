# Runtime
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=http://localhost:5173
AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Optional direct Postgres connection for migration tooling or future integration tests.
# The backend runtime uses the Supabase API values above.
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Terminal 3
T3N_API_KEY=<developer-key-from-terminal3-claim-page>
T3N_ENV=testnet
T3_NETWORK_URL=
T3_TENANT_DID=

# Later phases
T3_MATCH_CONTRACT_ID=
RECEIPT_KEY_VERSION=

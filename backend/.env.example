# ============================================================================
# GhostBroker backend (Heroku) — environment template
# Copy to backend/.env (gitignored) and fill in real values for each
# environment. Anything commented out is optional or has a sane default.
# Variables are grouped by the workspace that historically owned them so
# the migration from the old multi-workspace repo stays auditable.
# ============================================================================

# ---- Runtime --------------------------------------------------------------
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
# Comma-separated list of CORS origins the dashboard may call from.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SESSION_SECRET=replace_with_32_plus_char_hex_secret

# ---- Supabase (required) --------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
# Optional direct Postgres connection for migration tooling or future
# integration tests. The backend runtime uses the Supabase API values above.
# DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# ============================================================================
# Terminal 3 enclave (formerly `t3-enclave/.env.example`)
# ============================================================================
# Developer key from https://www.terminal3.io/claim-page
T3N_API_KEY=<developer-key-from-terminal3-claim-page>
T3N_ENV=testnet
# T3_NETWORK_URL=
# T3_TENANT_DID=
# T3_MATCH_CONTRACT_ID=
# T3_MATCHING_CONTRACT_VERSION=0.4.0

# ADK environment: which Terminal 3 network surface the enclave talks to.
#   - `sandbox`  — bundled offline mode (no SDK calls)
#   - `testnet`  — public T3N testnet (20,000 free tokens from the claim page);
#                  default for dev + live trades on Sepolia testnet
#   - `production` — billable mainnet (startup check warns if selected)
T3_ADK_ENV=testnet
# T3_AUTH_SDK_ENV=sandbox
# T3_AGENT_DELEGATION_MODE=dashboard
# T3_AGENT_GRANT_VERIFICATION_REQUIRED=true

# Sandbox token account + minimum balance gate.
T3_SANDBOX_TOKEN_ACCOUNT=<sandbox-token-account-or-did>
T3_MINIMUM_TOKEN_BALANCE=1
T3_PRIVATE_MAP_PREFIX=ghostbroker-dev

# ---- Verification mode ----------------------------------------------------
# The GhostBroker-style W3C VC verifier runs in `live` mode exclusively
# (full `EcdsaSecp256k1Signature2019` cryptographic verification inline,
# fail-closed on any exception). There is no T3_MODE / VC_VERIFY_MODE env
# var to set; the verifier's only mode is hard-coded.
# ---- Settlement (backend) -------------------------------------------------
SETTLEMENT_ASSET_CODE=USDC
# RECEIPT_KEY_VERSION=
# PORTFOLIO_SYNC_TOKEN=<32-plus-char-token>
ETHERSCAN_API_KEY=
SEPOLIA_WBTC_CONTRACT_ADDRESS=0x29f2D40B0605204364af54EC677bD022dA425d03
SEPOLIA_USDC_CONTRACT_ADDRESS=0x94a9D9AC8a22534E3FaCa9F4e7F2E2cf85d5E4C8

# ---- Chain rail (Sepolia ERC-20, opt-in) ----------------------------------
SETTLEMENT_RAIL_CHAIN_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/...
SETTLEMENT_RAIL_CHAIN_SEPOLIA_RELAYER_PRIVATE_KEY=0x...
SETTLEMENT_RAIL_CHAIN_SEPOLIA_RELAYER_CONTRACT_ADDRESS=0x...
SETTLEMENT_RAIL_CHAIN_SEPOLIA_DEPOSIT_WALLET_SEED=0x...
SETTLEMENT_RAIL_CHAIN_SEPOLIA_WBTC_ADDRESS=0x...
SETTLEMENT_RAIL_CHAIN_SEPOLIA_USDC_ADDRESS=0x...
SETTLEMENT_RAIL_CHAIN_SEPOLIA_CHAIN_ID=11155111
SETTLEMENT_RAIL_CHAIN_SEPOLIA_CONFIRM_TIMEOUT_SEC=90
# SETTLEMENT_RAIL_CHAIN_SEPOLIA_TEE_SIGNER_REF=t3_secret:...

# ============================================================================
# Hosted agents (formerly `agents/.env.example` + `agents/.env`)
# These power `npm run agent:hosted` (and the legacy buyer/seller CLIs).
# When the backend spawns a hosted agent it injects the GHOSTBROKER_* +
# HOSTED_* keys automatically; they're listed here for manual debugging.
# ============================================================================

# --- LLM provider keys (required for hosted agent) ---
# The backend injects GHOSTBROKER_* and HOSTED_* session keys automatically
# when spawning a hosted agent. Only LLM credentials need to live in .env.
# IMPORTANT: every provider that sets an *_API_KEY MUST also set the
# matching *_BASE_URL. There are no implicit defaults in the agent runtime
# — operators point each provider at the documented endpoint for their
# own deployment (Google's Gemini, Azure OpenAI, Groq Cloud, or a
# sanctioned self-hosted proxy). A missing *_BASE_URL fails fast at
# agent env-load time with a clear "config" error.
# GHOSTBROKER_URL=http://localhost:3001
GEMINI_API_KEY=sk_replace_me
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OPENAI_API_KEY=sk_replace_me
OPENAI_MODEL=gpt-5-nano
# Example for OpenAI Cloud. Swap for your Azure deployment URL when
# routing OpenAI-compatible traffic through Azure (e.g.
# https://<resource>.openai.azure.com/openai/v1).
OPENAI_BASE_URL=https://api.openai.com/v1
GROQ_API_KEY=gsk_replace_me
GROQ_MODEL=qwen/qwen3-32b
GROQ_BASE_URL=https://api.groq.com/openai/v1
# LLM_PROVIDER_CHAIN=gemini,openai,groq

# --- Agent identity ---
AGENT_IDENTITY_CONFIG_PATH=output/identities/agent_identity.json

# AGENTS_WORKSPACE_DIR=.
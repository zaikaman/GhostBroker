# Runtime
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
# Add your Vercel frontend origin(s) here before production deployment.
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-ghostbroker-frontend.vercel.app
AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Optional direct Postgres connection for migration tooling or future integration tests.
# The backend runtime uses the Supabase API values above.
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Terminal 3
T3N_API_KEY=<developer-key-from-terminal3-claim-page>
T3N_ENV=testnet
T3_NETWORK_URL=
T3_TENANT_DID=

# T3-enclave startup config. Leave at the documented defaults
# unless you know what you're doing. The enclave startup check
# (wired in `t3-enclave/src/sandbox/config.ts`) refuses to boot
# a production backend when `T3_ADK_ENV` is malformed, and emits
# a warning when `T3_MODE=live` is selected so operators know
# that cryptographic W3C VC verification via `@terminal3/verify_vc`
# is being requested.
T3_ADK_ENV=testnet
# Verification mode for the GhostBroker-style W3C VC verifier.
# `live` (default) requires cryptographic verification; the
# `setup:delegation` script produces an
# `EcdsaSecp256k1Signature2019` JWS so this works out of the
# box. `sandbox` / `structural` skip the crypto call. See
# `t3-enclave/src/auth/ghostbroker-delegation.ts` and
# `t3-enclave/.env.example` for the full contract.
T3_MODE=live

# Later phases
T3_MATCH_CONTRACT_ID=
RECEIPT_KEY_VERSION=
SETTLEMENT_ASSET_CODE=USDC
PORTFOLIO_SYNC_TOKEN=
ETHERSCAN_API_KEY=
SEPOLIA_WBTC_CONTRACT_ADDRESS=0x29f2D40B0605204364af54EC677bD022dA425d03
SEPOLIA_USDC_CONTRACT_ADDRESS=0x94a9D9AC8a22534E3FaCa9F4e7F2E2cf85d5E4C8

# Groq (LLM decision) — Required for Phase 2.5 demo agents to run
GROQ_API_KEY=<gsk_replace_me>